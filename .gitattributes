# Auto detect text files and perform LF normalization
* text=auto

# Source files
*.go text eol=lf
*.vue text eol=lf
*.ts text eol=lf
*.js text eol=lf
*.json text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.toml text eol=lf
*.md text eol=lf
*.txt text eol=lf

# Shell scripts must use LF
*.sh text eol=lf
docker-compose.*.sh text eol=lf

# Windows files should use CRLF
*.bat text eol=crlf
*.ps1 text eol=crlf
*.cmd text eol=crlf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary

# Generated files
*.exe binary
*.dll binary
*.so binary
*.dylib binary
