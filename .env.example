# ==================================
# GPT-Load 环境配置文件
# ==================================
# 说明：
# 1. 本文件配置的是【基础设施和服务器参数】，需要重启应用才能生效
# 2. 业务逻辑配置（超时、连接池、密钥验证等）请在【后台设置】中配置，支持热重载
# 3. 后台设置入口：登录 Web 界面 → 系统设置
# ==================================

# ==================================
# 服务器配置（仅环境变量）
# ==================================

# 服务器监听端口和主机
PORT=3001
HOST=0.0.0.0

# HTTP 服务器超时设置（单位：秒）
# 注意：这里是处理客户端请求的超时时间
# 转发到 AI 服务的超时请在【后台设置】中配置 request_timeout
SERVER_READ_TIMEOUT=60          # 读取请求头超时
SERVER_WRITE_TIMEOUT=600        # 写入响应超时
SERVER_IDLE_TIMEOUT=120         # 空闲连接超时
SERVER_GRACEFUL_SHUTDOWN_TIMEOUT=10  # 优雅关闭超时

# ==================================
# 集群配置（仅环境变量）
# ==================================

# 主从节点配置（多节点部署时使用）
# true = 从节点（仅处理代理请求，不执行后台任务）
# false 或不设置 = 主节点（执行数据库迁移、密钥验证、日志清理等后台任务）
IS_SLAVE=false

# ==================================
# 时区设置
# ==================================

TZ=Asia/Shanghai

# ==================================
# 安全配置（仅环境变量，必须设置）
# ==================================

# 管理后台认证密钥（必须设置，建议 16 位以上随机字符串）
# 用于保护 Web 界面和 API
AUTH_KEY=

# API 密钥加密密钥（可选，设置后数据库中的 API Key 会被加密存储）
# 建议设置以提高安全性，可使用任意字符串
ENCRYPTION_KEY=

# ==================================
# 数据库配置（仅环境变量）
# ==================================

# 数据库连接字符串（留空则使用 SQLite，数据文件位于 ./data/gpt-load.db）
# MySQL 示例：
# DATABASE_DSN=root:123456@tcp(mysql:3306)/gpt-load?charset=utf8mb4&parseTime=True&loc=Local
# PostgreSQL 示例：
# DATABASE_DSN=postgres://postgres:123456@postgres:5432/gpt-load?sslmode=disable
DATABASE_DSN=

# 数据库连接池配置
DB_MAX_IDLE_CONNS=50             # 最大空闲连接数（默认 50）
DB_MAX_OPEN_CONNS=500            # 最大打开连接数（默认 500）
DB_CONN_MAX_LIFETIME=3600        # 连接最大存活时间，单位秒（默认 3600 = 1小时）
DB_SLOW_THRESHOLD=1000           # 慢 SQL 阈值，单位毫秒（默认 1000 = 1秒）

# ==================================
# 缓存配置（仅环境变量）
# ==================================

# Redis 连接字符串（留空则使用内存存储，多节点部署时必须配置）
# 示例：redis://redis:6379/0
REDIS_DSN=

# ==================================
# 性能配置（仅环境变量）
# ==================================

# 最大并发请求数（服务器层面限制）
# 注意：转发到 AI 服务的连接池请在【后台设置】中配置 max_idle_conns
MAX_CONCURRENT_REQUESTS=100

# ==================================
# CORS 跨域配置（仅环境变量）
# ==================================

# 是否启用跨域（Web 前端需要）
ENABLE_CORS=true
ALLOWED_ORIGINS=*
ALLOWED_METHODS=GET,POST,PUT,DELETE,OPTIONS
ALLOWED_HEADERS=*
ALLOW_CREDENTIALS=false

# ==================================
# 日志配置（仅环境变量）
# ==================================

# 日志级别：debug, info, warn, error
LOG_LEVEL=info
# 日志格式：text, json
LOG_FORMAT=text
# 是否启用文件日志
LOG_ENABLE_FILE=true
# 日志文件路径
LOG_FILE_PATH=./data/logs/app.log

# ==================================
# 后台设置中的配置项（仅供参考，含默认值）
# ==================================
# 以下配置项请在 Web 后台【系统设置】中修改，支持热重载：
#
# 【请求相关】
# - request_timeout        : 转发到 AI 服务的请求超时（秒）【默认: 600】
# - connect_timeout        : 连接 AI 服务的超时（秒）【默认: 15】
# - idle_conn_timeout      : 空闲连接超时（秒）【默认: 120】
# - response_header_timeout: 等待响应头的超时（秒）【默认: 600】
# - max_idle_conns         : 最大空闲连接数【默认: 100】
# - max_idle_conns_per_host: 每个主机最大空闲连接数【默认: 50】
# - proxy_url              : 代理服务器地址【默认: 空】
#
# 【密钥管理】
# - max_retries                   : 请求失败最大重试次数【默认: 3】
# - blacklist_threshold           : 密钥拉黑阈值【默认: 3】
# - key_validation_interval_minutes: 密钥验证间隔（分钟）【默认: 60】
# - key_validation_concurrency    : 密钥验证并发数【默认: 10】
# - key_validation_timeout_seconds: 密钥验证超时（秒）【默认: 20】
#
# 【日志相关】
# - request_log_retention_days        : 请求日志保留天数【默认: 7】
# - request_log_write_interval_minutes: 日志写入间隔（分钟）【默认: 1】
# - enable_request_body_logging       : 是否记录请求体【默认: false】
#
# 【其他】
# - app_url   : 应用 URL（用于生成链接）【默认: http://localhost:3001】
# - proxy_keys: 代理访问密钥（用于调用代理 API）【默认: 空，需配置】
# ==================================

# ==================================
# 场景化配置参考
# ==================================
#
# 【低占用配置 - 个人使用/小团队】
# 适用于：1-2 核 CPU，2-4GB 内存，请求量 < 100 RPM
#
# DB_MAX_IDLE_CONNS=10
# DB_MAX_OPEN_CONNS=50
# DB_CONN_MAX_LIFETIME=3600
# DB_SLOW_THRESHOLD=2000
# REDIS_DSN=
# MAX_CONCURRENT_REQUESTS=100
# LOG_LEVEL=info
#
# 后台设置推荐：
# - 请求超时: 180
# - 连接超时: 15
# - 空闲连接超时: 60
# - 最大空闲连接数: 20
# - 每主机最大空闲连接数: 10
# - 密钥验证间隔: 120 分钟
#
# ----------------------------------
#
# 【高并发配置 - 生产环境】
# 适用于：4+ 核 CPU，8GB+ 内存，请求量 > 1000 RPM
#
# DB_MAX_IDLE_CONNS=1024
# DB_MAX_OPEN_CONNS=10240
# DB_CONN_MAX_LIFETIME=300
# DB_SLOW_THRESHOLD=10000
# REDIS_DSN=redis://127.0.0.1:6379/0
# DATABASE_DSN=mysql://user:pass@tcp(host:3306)/db
# MAX_CONCURRENT_REQUESTS=5000
# LOG_LEVEL=warn
# LOG_FORMAT=json
#
# 后台设置推荐：
# - 请求超时: 600
# - 连接超时: 10
# - 空闲连接超时: 120
# - 最大空闲连接数: 500
# - 每主机最大空闲连接数: 100
# - 密钥验证间隔: 30 分钟
# ==================================
